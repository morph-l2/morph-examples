# RPC URLs
MORPH_TESTNET_URL=https://rpc-hoodi.morph.network
MORPH_MAINNET_URL=https://rpc-quicknode.morph.network

# Private key of the EOA to be upgraded via EIP-7702 (no ETH needed for gas)
EOA_PRIVATE_KEY=0xabc123...

# Private key of the deployer / sponsor account (needs ETH to deploy and pay gas)
DEPLOYER_PRIVATE_KEY=0xabc123...
SPONSOR_PRIVATE_KEY=0xabc123...

# Deployed SimpleDelegation contract address (output from deploy script)
SIMPLE_DELEGATION_ADDRESS=0x0000000000000000000000000000000000000000

# Recipient address for the demo transfer
RECIPIENT_ADDRESS=0x000000000000000000000000000000000000dEaD
